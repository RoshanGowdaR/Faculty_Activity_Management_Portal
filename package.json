{
  "name": "faculty-activity-management-portal",
  "version": "1.0.0",
  "description": "Faculty Activity Management Portal",
  "scripts": {
    "setup": "npm install && npm install --prefix server && npm install --prefix client",
    "server": "npm run dev --prefix server",
